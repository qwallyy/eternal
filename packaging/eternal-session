#!/bin/sh

export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=eternal
export XDG_SESSION_DESKTOP=eternal

# Choose a writable log file, even when HOME/XDG_STATE_HOME is missing.
LOG_FILE="${ETERNAL_LOG_FILE:-}"
if [ -n "$LOG_FILE" ]; then
    log_dir="$(dirname "$LOG_FILE")"
    mkdir -p "$log_dir" 2>/dev/null || LOG_FILE=""
fi

if [ -z "$LOG_FILE" ]; then
    uid="$(id -u 2>/dev/null || echo unknown)"
    for base in "${XDG_STATE_HOME:-}" "${HOME:-}/.local/state" "${HOME:-}/.cache" "/tmp"; do
        [ -n "$base" ] || continue
        case "$base" in
            /tmp) candidate="$base/eternal-session-$uid.log" ;;
            *) candidate="$base/eternal/eternal-session.log" ;;
        esac
        candidate_dir="$(dirname "$candidate")"
        mkdir -p "$candidate_dir" 2>/dev/null || continue
        : >>"$candidate" 2>/dev/null || continue
        LOG_FILE="$candidate"
        break
    done
fi

[ -n "$LOG_FILE" ] || LOG_FILE="/tmp/eternal-session.log"
export ETERNAL_LOG_FILE="$LOG_FILE"

if ! exec >>"$LOG_FILE" 2>&1; then
    LOG_FILE="/tmp/eternal-session-fallback.log"
    export ETERNAL_LOG_FILE="$LOG_FILE"
    exec >>"$LOG_FILE" 2>&1
fi

echo "==== $(date) ===="
echo "Starting eternal-session"
echo "Log file: $LOG_FILE"

# LightDM can race device/session initialization for Wayland sessions.
# Allow a short delay (default 1s) when started from lightdm.
parent_comm="$(ps -p "$PPID" -o comm= 2>/dev/null || true)"
case "$parent_comm" in
    lightdm*|lightdm-session)
        sleep "${ETERNAL_LIGHTDM_DELAY:-1}"
        ;;
esac

# Pick a libseat backend that matches the session type.
# For display-manager/systemd sessions, logind is the correct default.
if [ -z "${LIBSEAT_BACKEND:-}" ]; then
    if [ -n "${ETERNAL_SEAT_BACKEND:-}" ]; then
        LIBSEAT_BACKEND="$ETERNAL_SEAT_BACKEND"
    elif [ -n "${XDG_SESSION_ID:-}" ] && command -v loginctl >/dev/null 2>&1 \
        && loginctl show-session "$XDG_SESSION_ID" >/dev/null 2>&1; then
        LIBSEAT_BACKEND=logind
    else
        case "$parent_comm" in
            lightdm*|lightdm-session)
                LIBSEAT_BACKEND=logind
                ;;
            *)
                seatd_sock="${SEATD_SOCK:-/run/seatd.sock}"
                if [ -S "$seatd_sock" ] && [ -r "$seatd_sock" ] && [ -w "$seatd_sock" ]; then
                    LIBSEAT_BACKEND=seatd
                else
                    LIBSEAT_BACKEND=logind
                fi
                ;;
        esac
    fi
    export LIBSEAT_BACKEND
fi

echo "LIBSEAT_BACKEND=$LIBSEAT_BACKEND"
echo "XDG_SESSION_ID=${XDG_SESSION_ID:-unset}"
echo "XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-unset}"
if [ "${LIBSEAT_BACKEND}" = "seatd" ]; then
    echo "SEATD_SOCK=${SEATD_SOCK:-/run/seatd.sock}"
fi

# Detect common virtual GPU vendors used by virt-manager video models.
is_virtual_gpu=0
if command -v systemd-detect-virt >/dev/null 2>&1 && systemd-detect-virt -q; then
    is_virtual_gpu=1
fi
for vpath in /sys/class/drm/card*/device/vendor; do
    [ -r "$vpath" ] || continue
    vendor="$(cat "$vpath" 2>/dev/null || true)"
    case "$vendor" in
        0x1af4|0x1b36|0x1234|0x80ee|0x15ad)
            is_virtual_gpu=1
            break
            ;;
    esac
done

# VM-friendly wlroots defaults. Users can override them in their environment.
# Applies to:
# - virtio-gpu (0x1af4)
# - qxl (0x1b36)
# - bochs/stdvga (0x1234)
# - virtualbox (0x80ee)
# - vmware (0x15ad)
if [ "$is_virtual_gpu" -eq 1 ]; then
    export WLR_NO_HARDWARE_CURSORS="${WLR_NO_HARDWARE_CURSORS:-1}"
    export WLR_RENDERER_ALLOW_SOFTWARE="${WLR_RENDERER_ALLOW_SOFTWARE:-1}"
    export WLR_RENDERER="${WLR_RENDERER:-pixman}"
    export WLR_DRM_NO_ATOMIC="${WLR_DRM_NO_ATOMIC:-1}"
fi

# Preflight: only fail when there are no input device nodes at all.
# With logind/seatd, direct readability of /dev/input/event* is not required.
has_input_nodes=0
for input_node in /dev/input/event*; do
    [ -e "$input_node" ] || continue
    has_input_nodes=1
    break
done

if [ "$has_input_nodes" -ne 1 ]; then
    echo "No input devices found under /dev/input/event*"
    echo "LIBSEAT_BACKEND=$LIBSEAT_BACKEND"
    if [ "${ETERNAL_ALLOW_NO_INPUT:-0}" = "1" ]; then
        echo "Proceeding because ETERNAL_ALLOW_NO_INPUT=1"
        export WLR_LIBINPUT_NO_DEVICES=1
    else
        echo "Refusing to start without any input device nodes."
        echo "Set ETERNAL_ALLOW_NO_INPUT=1 to override."
        exit 1
    fi
fi

if command -v dbus-run-session >/dev/null 2>&1; then
    exec dbus-run-session /usr/bin/eternal
fi

exec /usr/bin/eternal
